---
layout: layout.njk
---

<header>
    <h2>{{ title }}</h2>
    <time datetime="{{ date | isoDate }}">{{ date | parseDate | readableDate }}</time>
</header>
<article class="normal-width">
    {{ content | safe }}
    {%- if collections.posts %}
        {%- set previousPost = collections.posts | getPreviousCollectionItem %}
        {%- set nextPost = collections.posts | getNextCollectionItem %}
        {%- if nextPost or previousPost %}
            <div class="pagination">
                {%- if previousPost %}
                    <a href="{{ previousPost.url }}">
                        <div class="pagination-button pagination-prev">
                            <div class="pagination-linktext">
                                précédent: {{ previousPost.data.title }}
                            </div>
                        </div>
                    </a>
                {% endif %}
                {%- if nextPost %}
                    <a href="{{ nextPost.url }}">
                        <div class="pagination-button pagination-next">
                            <div class="pagination-linktext">
                                suivant: {{ nextPost.data.title }}
                            </div>
                        </div>
                    </a>
                {% endif %}
            </div>
        {%- endif %}
    {%- endif %}
</article>