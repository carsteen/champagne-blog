<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }} | Champagne</title>
    <link rel="stylesheet" href="/style.css">
  </head>
  <body>
    <div class="site-layout">
      <aside class="site-sidebar" aria-label="Navigation principale">
        <div class="site-logo">
          <a href="/">
            <img src="/img/logo_champagne.png" alt="Champagne" eleventy:ignore width="300">
          </a>
        </div>
        <nav class="site-nav">
          <ul>
            <li><a href="/">Blog</a></li>
            <li><a href="/about/">Le projet</a></li>
            <li><a href="/posts_list/">Tous les posts</a></li>
          </ul>
        </nav>
      </aside>
      <main class="site-main">
        <div class="page-content">
          {{ content | safe }}
        </div>
        {% include "footer.njk" %}
      </main>
    </div>
  </body>
</html>