---
layout: layout.njk
title: Blog
pagination:
  data: collections.blog
  size: 100
  reverse: true
permalink: /blog/
---

<h1>Blog</h1>
<ul>
{% for post in collections.blog | reverse %}
  <li>
    <a href="{{ post.url }}">{{ post.data.title }}</a> - {{ post.date | date("dd/MM/yyyy") }}
  </li>
{% endfor %}
</ul>
