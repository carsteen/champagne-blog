---
layout: layout.njk
title: Articles
permalink: /posts_list/
---

<section class="articles-list" aria-labelledby="articles-title">
  <ul>
    {% for post in collections.posts | reverse %}
    <li>
      <time datetime="{{ post.date | isoDate }}">{{ post.date | date("dd/MM/yyyy") }}</time>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
    </li>
    {% endfor %}
  </ul>
</section>