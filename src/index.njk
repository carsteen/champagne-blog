---
layout: layout.njk
title: News
---

<section class="articles-feed" aria-labelledby="news-title">
  {% set latestPosts = collections.posts | reverse | limit(3) %}
  {% if latestPosts | length %}
    <div class="articles-stack">
      {% for post in latestPosts %}
        <article class="article-card">
          <header>
            <h2 class="article-title">
              <a href="{{ post.url }}">{{ post.data.title }}</a>
            </h2>
            <p class="article-date">
              <time datetime="{{ post.date | isoDate }}">{{ post.date | date("dd/MM/yyyy") }}</time>
            </p>
          </header>
          <div class="article-body">
            {{ post.templateContent | safe }}
          </div>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <p>Aucun article n’a encore été publié.</p>
  {% endif %}
</section>